# Normalize all text files to LF repository-wide
* text=auto eol=lf

# Windows batch/cmd files must stay CRLF or they break on Windows runners
*.cmd text eol=crlf
*.bat text eol=crlf

# Keep first-party generated dist artifacts normalized across OS environments
packages/*/dist/**/*.js text eol=lf
packages/*/dist/**/*.d.ts text eol=lf
packages/*/dist/**/*.map text eol=lf
packages/*/dist/**/*.json text eol=lf
packages/*/dist/bundle.js text eol=lf
packages/*/dist/bundle.js.map text eol=lf
packages/*/dist/package.json text eol=lf
packages/*/dist/runtime-dependencies.json text eol=lf

# Keep vendored runtime dependencies byte-for-byte as produced by npm
packages/*/dist/node_modules/* -text
packages/*/dist/node_modules/**/* -text
